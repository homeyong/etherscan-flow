{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/homeyong/etherscan-flow/schema/case.schema.json",
  "title": "Etherscan Flow Case",
  "description": "The single JSON document produced by the etherscan-flow skill. Encodes the contract documented in references/output-spec.md. Every address, amount, and txhash must come from a live Etherscan API response — this schema checks shape, not provenance.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "schemaVersion", "nodes", "edges", "_meta"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^case-[0-9a-z-]+$",
      "description": "case-{SHORT_ID}; SHORT_ID is 8 lowercase hex chars of the seed (Hard rule 7)."
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "schemaVersion": { "type": "integer", "const": 1 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "_meta": { "$ref": "#/$defs/meta" }
  },
  "$defs": {
    "address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$",
      "description": "42-char hex address. Never an ENS name, alias, or placeholder (Hard rule 13)."
    },
    "txhash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$"
    },
    "decimalString": {
      "type": ["string", "null"],
      "pattern": "^-?[0-9]+(\\.[0-9]+)?$",
      "description": "Bare human-readable decimal, no unit suffix, no raw wei. null when unresolved."
    },
    "nodeRole": {
      "type": "string",
      "enum": [
        "wallet",
        "erc20_token",
        "nft_contract",
        "defi_pool",
        "multisig",
        "staking_contract",
        "lending_protocol",
        "dao_contract",
        "attacker_eoa",
        "scam_contract",
        "victim_wallet",
        "intermediate_wallet",
        "cex_deposit",
        "dex_router",
        "mixer_contract",
        "bridge",
        "nft_drainer_contract",
        "sweeper_bot",
        "unknown_eoa",
        "unknown_contract"
      ]
    },
    "edgeType": {
      "type": "string",
      "enum": [
        "transfer",
        "token_transfer",
        "dex_swap",
        "bridge",
        "nft",
        "approve",
        "contract_call",
        "mint",
        "burn",
        "stake",
        "unstake",
        "borrow",
        "repay",
        "liquidity_add",
        "liquidity_remove"
      ]
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "address", "chainid", "role", "hop"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z0-9_]{2,12}$" },
        "address": { "$ref": "#/$defs/address" },
        "chainid": { "type": "integer", "minimum": 1 },
        "label": { "type": ["string", "null"], "maxLength": 200 },
        "subLabel": {
          "type": ["string", "null"],
          "maxLength": 200,
          "description": "ENS name or second-line alias; never replaces address."
        },
        "role": { "$ref": "#/$defs/nodeRole" },
        "hop": {
          "type": "integer",
          "minimum": 0,
          "description": "0-indexed from the seed. Seed/scope addresses are hop 0."
        },
        "balance": {
          "$ref": "#/$defs/decimalString",
          "description": "Native-coin balance, or null when not fetched. Never a fabricated 0."
        },
        "notes": { "type": ["string", "null"], "maxLength": 200 },
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "type", "txhash", "chainid"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "description": "A node id." },
        "target": { "type": "string", "description": "A node id." },
        "amount": { "$ref": "#/$defs/decimalString" },
        "token": { "type": ["string", "null"], "maxLength": 200 },
        "txcount": { "type": "integer", "minimum": 1 },
        "type": { "$ref": "#/$defs/edgeType" },
        "txhash": { "$ref": "#/$defs/txhash" },
        "txhashes": {
          "type": "array",
          "items": { "$ref": "#/$defs/txhash" },
          "maxItems": 100,
          "description": "Every merged hash, ascending block order, txhashes[0] === txhash."
        },
        "chainid": { "type": "integer", "minimum": 1 },
        "timestamp": {
          "type": ["string", "null"],
          "description": "ISO 8601, or null when unresolved."
        }
      }
    },
    "analysisAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token", "token_address", "gross_amount", "returned_or_recovered", "net_amount"],
      "properties": {
        "token": { "type": "string", "minLength": 1, "maxLength": 200 },
        "token_address": {
          "anyOf": [
            { "$ref": "#/$defs/address" },
            { "type": "null" }
          ]
        },
        "gross_amount": { "$ref": "#/$defs/decimalString" },
        "returned_or_recovered": { "$ref": "#/$defs/decimalString" },
        "net_amount": { "$ref": "#/$defs/decimalString" }
      }
    },
    "analysisEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim", "kind", "sources", "txhashes", "addresses", "block", "selector"],
      "properties": {
        "claim": { "type": "string", "minLength": 1, "maxLength": 200 },
        "kind": { "type": "string", "enum": ["observed", "inferred", "unverified"] },
        "sources": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 200 },
          "minItems": 1
        },
        "txhashes": { "type": "array", "items": { "$ref": "#/$defs/txhash" } },
        "addresses": { "type": "array", "items": { "$ref": "#/$defs/address" } },
        "block": { "type": ["integer", "null"], "minimum": 0 },
        "selector": { "type": ["string", "null"], "pattern": "^0x[a-fA-F0-9]{8}$" }
      }
    },
    "analysisAlternative": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis", "assessment", "evidence_for", "evidence_against"],
      "properties": {
        "hypothesis": { "type": "string", "minLength": 1, "maxLength": 200 },
        "assessment": { "type": "string", "enum": ["plausible", "unlikely", "unresolved"] },
        "evidence_for": { "type": "array", "items": { "type": "string", "maxLength": 200 } },
        "evidence_against": { "type": "array", "items": { "type": "string", "maxLength": 200 } }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "incident_type", "summary", "attack_vector", "root_cause", "confidence",
        "decisive_txhashes", "evidence", "losses_by_token", "attacker_profit_by_token",
        "alternative_hypotheses", "limitations"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["confirmed", "probable", "possible", "insufficient_evidence"] },
        "incident_type": {
          "type": "string",
          "enum": [
            "approval_drain", "permit_or_signature_abuse", "private_key_compromise",
            "social_engineering_transfer", "access_control_exploit", "proxy_or_upgrade_exploit",
            "reentrancy", "oracle_manipulation", "price_or_reserve_manipulation",
            "flash_loan_assisted_exploit", "accounting_or_rounding_exploit", "rug_pull",
            "malicious_token", "nft_drain", "laundering_only", "unknown"
          ]
        },
        "summary": { "type": "string", "minLength": 1, "maxLength": 200 },
        "attack_vector": { "type": ["string", "null"], "maxLength": 200 },
        "root_cause": { "type": ["string", "null"], "maxLength": 200 },
        "confidence": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
        "decisive_txhashes": { "type": "array", "items": { "$ref": "#/$defs/txhash" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/analysisEvidence" } },
        "losses_by_token": { "type": "array", "items": { "$ref": "#/$defs/analysisAsset" } },
        "attacker_profit_by_token": { "type": "array", "items": { "$ref": "#/$defs/analysisAsset" } },
        "alternative_hypotheses": { "type": "array", "items": { "$ref": "#/$defs/analysisAlternative" } },
        "limitations": { "type": "array", "items": { "type": "string", "maxLength": 200 } }
      }
    },
    "gapEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "detail"],
      "properties": {
        "type": { "type": "string", "minLength": 1, "maxLength": 200 },
        "detail": { "type": "string", "minLength": 1, "maxLength": 200 },
        "claim": { "type": "string", "minLength": 1, "maxLength": 200 },
        "endpoint": { "type": "string", "minLength": 1, "maxLength": 200 },
        "error": { "type": "string", "minLength": 1, "maxLength": 200 }
      },
      "if": {
        "properties": {
          "type": { "pattern": "(_unavailable|_incomplete|_empty)$" }
        },
        "required": ["type"]
      },
      "then": { "required": ["type", "detail", "endpoint"] }
    },
    "pattern": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "evidence_txhash"],
      "properties": {
        "pattern": { "type": "string", "minLength": 1, "maxLength": 200 },
        "evidence_txhash": {
          "anyOf": [
            { "$ref": "#/$defs/txhash" },
            { "type": "null" }
          ]
        }
      }
    },
    "meta": {
      "type": "object",
      "required": ["created_at", "mode", "chain", "chainid", "analysis", "gaps", "disclaimer"],
      "properties": {
        "created_at": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["strict_trace", "business_entity_profile"]
        },
        "chain": { "type": "string" },
        "chainid": { "type": "integer", "minimum": 1 },
        "chains": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["chain", "chainid"],
            "properties": {
              "chain": { "type": "string" },
              "chainid": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "seed_txhashes": {
          "type": "array",
          "items": { "$ref": "#/$defs/txhash" }
        },
        "seed_addresses": {
          "type": "array",
          "items": { "$ref": "#/$defs/address" }
        },
        "hops_traced": { "type": "integer", "minimum": 0 },
        "trace_window": { "type": ["object", "null"] },
        "financials": { "type": ["object", "null"] },
        "analysis": {
          "anyOf": [
            { "$ref": "#/$defs/analysis" },
            { "type": "null" }
          ]
        },
        "business_profile": { "type": ["object", "null"] },
        "performance": { "type": ["object", "null"] },
        "timeline": { "type": "array" },
        "patterns": { "type": "array", "items": { "$ref": "#/$defs/pattern" } },
        "candidates": { "type": "array" },
        "gaps": { "type": "array", "items": { "$ref": "#/$defs/gapEntry" } },
        "disclaimer": { "type": "string" }
      }
    }
  }
}
